  "cells": [
    {
      "cell_type": "code",
      "source": [
        "# ============================================================\n",
        "# Ghana Maternal Health Q&A (English) - Multi-JSON Batches Loader\n",
        "# Build Retrieval Model (Embeddings + FAISS) + Export for Flask\n",
        "#\n",
        "# Output artifacts:\n",
        "#  - export_ghana_qa/qa_train.jsonl\n",
        "#  - export_ghana_qa/qa_faiss.index\n",
        "#  - export_ghana_qa/meta.json\n",
        "#  - ghana_qa_flask_artifacts.zip\n",
        "# ============================================================\n",
        "\n",
        "!pip -q install kaggle pandas numpy scikit-learn sentence-transformers faiss-cpu\n",
        "\n",
        "import os, json, re, zipfile\n",
        "import numpy as np\n",
        "import pandas as pd\n",
        "from sklearn.model_selection import train_test_split\n",
        "from sentence_transformers import SentenceTransformer\n",
        "import faiss\n",
        "\n",
        "# ----------------------------\n",
        "# 1) Kaggle setup (upload kaggle.json)\n",
        "# ----------------------------\n",
        "from google.colab import files\n",
        "print(\"Upload kaggle.json now...\")\n",
        "files.upload()\n",
        "\n",
        "!mkdir -p ~/.kaggle\n",
        "!cp kaggle.json ~/.kaggle/\n",
        "!chmod 600 ~/.kaggle/kaggle.json\n",
        "\n",
        "# ----------------------------\n",
        "# 2) Download dataset\n",
        "# ----------------------------\n",
        "DATASET_SLUG = \"ghanaairesnet/ghana-maternal-health-q-and-a-dataset-english\"\n",
        "OUT_DIR = \"/content/ghana_maternal_qa\"\n",
        "os.makedirs(OUT_DIR, exist_ok=True)\n",
        "\n",
        "!kaggle datasets download -d {DATASET_SLUG} -p {OUT_DIR} --unzip\n",
        "\n",
        "# ----------------------------\n",
        "# 3) Find all batch JSON files\n",
        "# ----------------------------\n",
        "BATCH_DIR = os.path.join(OUT_DIR, \"maternal_health_dataset_english\", \"batches\")\n",
        "\n",
        "if not os.path.exists(BATCH_DIR):\n",
        "    raise FileNotFoundError(f\"Batch folder not found: {BATCH_DIR}. Check unzip output.\")\n",
        "\n",
        "json_paths = sorted([\n",
        "    os.path.join(BATCH_DIR, f)\n",
        "    for f in os.listdir(BATCH_DIR)\n",
        "    if f.lower().endswith(\".json\")\n",
        "])\n",
        "\n",
        "print(\"Total batch files:\", len(json_paths))\n",
        "print(\"Example:\", json_paths[:3])\n",
        "\n",
        "# ----------------------------\n",
        "# 4) Robust JSON parsing to extract Q/A\n",
        "# ----------------------------\n",
        "def clean_text(s: str) -> str:\n",
        "    s = (\"\" if s is None else str(s))\n",
        "    s = s.replace(\"\\n\", \" \").replace(\"\\r\", \" \")\n",
        "    s = re.sub(r\"\\s+\", \" \", s).strip()\n",
        "    return s\n",
        "\n",
        "# Candidate keys that might appear in the JSON structure\n",
        "Q_KEYS = [\"question\", \"q\", \"prompt\", \"query\", \"user_question\", \"input\"]\n",
        "A_KEYS = [\"answer\", \"a\", \"response\", \"reply\", \"bot_answer\", \"output\"]\n",
        "\n",
        "def extract_pairs(obj):\n",
        "    \"\"\"\n",
        "    Accepts obj loaded from a JSON file.\n",
        "    Returns list of dicts: [{\"question\":..., \"answer\":...}, ...]\n",
        "    Handles:\n",
        "      - list of dicts\n",
        "      - dict with keys like \"data\"/\"items\"/\"qa\"/\"records\"\n",
        "      - nested shapes (we scan dicts)\n",
        "    \"\"\"\n",
        "    pairs = []\n",
        "\n",
        "    def handle_item(item):\n",
        "        if not isinstance(item, dict):\n",
        "            return\n",
        "        keys = {str(k).strip().lower(): k for k in item.keys()}\n",
        "\n",
        "        q_col = None\n",
        "        a_col = None\n",
        "\n",
        "        # direct key match\n",
        "        for k in Q_KEYS:\n",
        "            if k in keys:\n",
        "                q_col = keys[k]\n",
        "                break\n",
        "        for k in A_KEYS:\n",
        "            if k in keys:\n",
        "                a_col = keys[k]\n",
        "                break\n",
        "\n",
        "        # fuzzy contains\n",
        "        if q_col is None:\n",
        "            for lk, orig in keys.items():\n",
        "                if \"question\" in lk or \"prompt\" in lk or \"query\" in lk:\n",
        "                    q_col = orig\n",
        "                    break\n",
        "        if a_col is None:\n",
        "            for lk, orig in keys.items():\n",
        "                if \"answer\" in lk or \"response\" in lk or \"reply\" in lk:\n",
        "                    a_col = orig\n",
        "                    break\n",
        "\n",
        "        if q_col is not None and a_col is not None:\n",
        "            q = clean_text(item.get(q_col))\n",
        "            a = clean_text(item.get(a_col))\n",
        "            if len(q) > 3 and len(a) > 3:\n",
        "                pairs.append({\"question\": q, \"answer\": a})\n",
        "\n",
        "    def walk(x):\n",
        "        if isinstance(x, list):\n",
        "            for it in x:\n",
        "                walk(it)\n",
        "        elif isinstance(x, dict):\n",
        "            # maybe this dict itself is a QA record\n",
        "            handle_item(x)\n",
        "            # also walk values\n",
        "            for v in x.values():\n",
        "                walk(v)\n",
        "\n",
        "    # If top-level is dict with known container keys, prioritize them\n",
        "    if isinstance(obj, dict):\n",
        "        for container in [\"data\", \"items\", \"qa\", \"records\", \"examples\"]:\n",
        "            if container in obj and isinstance(obj[container], (list, dict)):\n",
        "                walk(obj[container])\n",
        "                if pairs:\n",
        "                    return pairs\n",
        "\n",
        "    walk(obj)\n",
        "    return pairs\n",
        "\n",
        "rows = []\n",
        "for p in json_paths:\n",
        "    with open(p, \"r\", encoding=\"utf-8\") as f:\n",
        "        obj = json.load(f)\n",
        "    pairs = extract_pairs(obj)\n",
        "    for pr in pairs:\n",
        "        pr[\"source_file\"] = os.path.basename(p)\n",
        "        rows.append(pr)\n",
        "\n",
        "df = pd.DataFrame(rows)\n",
        "print(\"Extracted pairs:\", len(df))\n",
        "print(df.head(5))\n",
        "\n",
        "if len(df) == 0:\n",
        "    raise RuntimeError(\"No Q&A pairs extracted. We need to inspect one JSON file structure.\")\n",
        "\n",
        "# ----------------------------\n",
        "# 5) Clean + deduplicate\n",
        "# ----------------------------\n",
        "df[\"question\"] = df[\"question\"].apply(clean_text)\n",
        "df[\"answer\"] = df[\"answer\"].apply(clean_text)\n",
        "\n",
        "df = df[(df[\"question\"].str.len() > 3) & (df[\"answer\"].str.len() > 3)].copy()\n",
        "df = df.drop_duplicates(subset=[\"question\", \"answer\"]).reset_index(drop=True)\n",
        "\n",
        "print(\"After dedupe:\", len(df))\n",
        "print(\"Sample:\\n\", df.sample(3, random_state=42)[[\"question\",\"answer\"]])\n",
        "\n",
        "# ----------------------------\n",
        "# 6) Train/test split\n",
        "# ----------------------------\n",
        "train_df, test_df = train_test_split(df, test_size=0.15, random_state=42)\n",
        "train_df = train_df.reset_index(drop=True)\n",
        "test_df  = test_df.reset_index(drop=True)\n",
        "\n",
        "train_questions = train_df[\"question\"].tolist()\n",
        "train_answers   = train_df[\"answer\"].tolist()\n",
        "\n",
        "test_questions  = test_df[\"question\"].tolist()\n",
        "test_answers    = test_df[\"answer\"].tolist()\n",
        "\n",
        "print(\"Train:\", len(train_df), \"Test:\", len(test_df))\n",
        "\n",
        "# ----------------------------\n",
        "# 7) Build embeddings + FAISS index\n",
        "# ----------------------------\n",
        "MODEL_NAME = \"sentence-transformers/all-MiniLM-L6-v2\"\n",
        "embedder = SentenceTransformer(MODEL_NAME)\n",
        "\n",
        "print(\"Embedding train questions...\")\n",
        "train_emb = embedder.encode(\n",
        "    train_questions,\n",
        "    batch_size=64,\n",
        "    show_progress_bar=True,\n",
        "    normalize_embeddings=True\n",
        ")\n",
        "train_emb = np.array(train_emb, dtype=\"float32\")\n",
        "\n",
        "dim = train_emb.shape[1]\n",
        "index = faiss.IndexFlatIP(dim)  # cosine via dot-product (normalized vectors)\n",
        "index.add(train_emb)\n",
        "\n",
        "print(\"FAISS built. ntotal:\", index.ntotal, \"dim:\", dim)\n",
        "\n",
        "# ----------------------------\n",
        "# 8) Evaluate retrieval (strict exact-answer match)\n",
        "# ----------------------------\n",
        "def retrieval_metrics(k_list=(1,3,5,10)):\n",
        "    test_emb = embedder.encode(\n",
        "        test_questions,\n",
        "        batch_size=64,\n",
        "        show_progress_bar=True,\n",
        "        normalize_embeddings=True\n",
        "    ).astype(\"float32\")\n",
        "\n",
        "    max_k = max(k_list)\n",
        "    sims, idxs = index.search(test_emb, max_k)\n",
        "\n",
        "    correct = {k: 0 for k in k_list}\n",
        "    rr_sum = 0.0\n",
        "\n",
        "    for i in range(len(test_questions)):\n",
        "        gold = test_answers[i]\n",
        "        retrieved = [train_answers[j] for j in idxs[i] if j >= 0]\n",
        "\n",
        "        for k in k_list:\n",
        "            if gold in retrieved[:k]:\n",
        "                correct[k] += 1\n",
        "\n",
        "        rank = None\n",
        "        for r, ans in enumerate(retrieved, start=1):\n",
        "            if ans == gold:\n",
        "                rank = r\n",
        "                break\n",
        "        if rank is not None:\n",
        "            rr_sum += 1.0 / rank\n",
        "\n",
        "    n = len(test_questions)\n",
        "    recall = {k: correct[k]/n for k in k_list}\n",
        "    mrr = rr_sum/n\n",
        "    return recall, mrr\n",
        "\n",
        "recall, mrr = retrieval_metrics()\n",
        "print(\"\\nMetrics (strict exact-answer match):\")\n",
        "for k, v in recall.items():\n",
        "    print(f\"Recall@{k}: {v:.3f}\")\n",
        "print(f\"MRR: {mrr:.3f}\")\n",
        "\n",
        "# ----------------------------\n",
        "# 9) Quick demo\n",
        "# ----------------------------\n",
        "def ask_bot(q, top_k=3):\n",
        "    q = clean_text(q)\n",
        "    q_emb = embedder.encode([q], normalize_embeddings=True).astype(\"float32\")\n",
        "    sims, idxs = index.search(q_emb, top_k)\n",
        "    out = []\n",
        "    for score, j in zip(sims[0], idxs[0]):\n",
        "        out.append({\n",
        "            \"score\": float(score),\n",
        "            \"matched_question\": train_questions[j],\n",
        "            \"answer\": train_answers[j]\n",
        "        })\n",
        "    return out\n",
        "\n",
        "demo_q = \"I have nausea in early pregnancy. What should I do?\"\n",
        "print(\"\\nDEMO:\", demo_q)\n",
        "for i, r in enumerate(ask_bot(demo_q, top_k=3), 1):\n",
        "    print(f\"\\nTop {i} | score={r['score']:.3f}\")\n",
        "    print(\"Matched Q:\", r[\"matched_question\"])\n",
        "    print(\"Answer:\", r[\"answer\"][:300], \"...\" if len(r[\"answer\"])>300 else \"\")\n",
        "\n",
        "# ----------------------------\n",
        "# 10) Export artifacts for Flask backend\n",
        "# ----------------------------\n",
        "EXPORT_DIR = \"/content/export_ghana_qa\"\n",
        "os.makedirs(EXPORT_DIR, exist_ok=True)\n",
        "\n",
        "qa_jsonl = os.path.join(EXPORT_DIR, \"qa_train.jsonl\")\n",
        "with open(qa_jsonl, \"w\", encoding=\"utf-8\") as f:\n",
        "    for q, a in zip(train_questions, train_answers):\n",
        "        f.write(json.dumps({\"question\": q, \"answer\": a}, ensure_ascii=False) + \"\\n\")\n",
        "\n",
        "index_path = os.path.join(EXPORT_DIR, \"qa_faiss.index\")\n",
        "faiss.write_index(index, index_path)\n",
        "\n",
        "meta = {\n",
        "    \"embedding_model\": MODEL_NAME,\n",
        "    \"vector_dim\": int(dim),\n",
        "    \"normalize_embeddings\": True,\n",
        "    \"index_type\": \"IndexFlatIP\",\n",
        "    \"train_rows\": len(train_df),\n",
        "    \"test_rows\": len(test_df),\n",
        "    \"metrics_strict\": {\"recall\": recall, \"mrr\": mrr},\n",
        "    \"source\": \"Ghana Maternal Health Q&A (English) batches/*.json\"\n",
        "}\n",
        "meta_path = os.path.join(EXPORT_DIR, \"meta.json\")\n",
        "json.dump(meta, open(meta_path, \"w\", encoding=\"utf-8\"), indent=2)\n",
        "\n",
        "zip_path = \"/content/ghana_qa_flask_artifacts.zip\"\n",
        "with zipfile.ZipFile(zip_path, \"w\", zipfile.ZIP_DEFLATED) as z:\n",
        "    z.write(qa_jsonl, arcname=\"qa_train.jsonl\")\n",
        "    z.write(index_path, arcname=\"qa_faiss.index\")\n",
        "    z.write(meta_path, arcname=\"meta.json\")\n",
        "\n",
        "print(\"\\n✅ Export complete!\")\n",
        "print(\"Artifacts folder:\", EXPORT_DIR)\n",
        "print(\"ZIP for Flask backend:\", zip_path)"
      ],
